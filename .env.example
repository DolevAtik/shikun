# Copy to .env and adjust. Never commit .env.

# Postgres runs on 5433 to avoid colliding with a local Postgres on 5432.
DATABASE_URL="postgresql://moch:moch_dev_password@localhost:5433/moch_eep?schema=public"
# Migrations need a direct (unpooled) session. Locally it is the same database;
# on managed Postgres (Neon) DATABASE_URL is the pooled string and this is not.
DIRECT_URL="postgresql://moch:moch_dev_password@localhost:5433/moch_eep?schema=public"

# Dev-only secrets. Replace in any deployed environment.
JWT_SECRET="dev-only-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

API_PORT=4000
# Comma-separated. Include both the employee app and the admin console.
WEB_ORIGIN="http://localhost:3001,http://localhost:3002"

# Object storage (MinIO locally, any S3 bucket in production)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="moch-media"
S3_ACCESS_KEY="moch_minio"
S3_SECRET_KEY="moch_dev_password"
# The bucket's public read domain, when it differs from the S3 API endpoint
# (it always does on a managed bucket). Unset locally: MinIO serves both.
# S3_PUBLIC_URL="https://media.example.com"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Hostname (no scheme) of the media bucket, for next/image. Unset locally.
# NEXT_PUBLIC_MEDIA_HOST="media.example.com"
