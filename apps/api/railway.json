{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm turbo run build --filter=@moch/api"
  },
  "deploy": {
    "startCommand": "cd ../.. && pnpm --filter @moch/api db:deploy && pnpm --filter @moch/api start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
